# WireGuard configuration – Road-Client
# ECN2026 project
# Sensitive values such as keys and endpoint have been removed.

[Interface]
PrivateKey = <REDACTED>
Address = 10.100.0.24/32
ListenPort = 51820

# Disable DNS when only accessing site-to-site resources
# DNS = 1.1.1.1

# VPN hub – VPS in Germany
[Peer]
PublicKey = <REDACTED>
Endpoint = <REDACTED>

# Site-to-site access (only VPN networks reachable)
AllowedIPs = 10.100.0.1/32

# Full tunnel (route all traffic through VPN)
# AllowedIPs = 0.0.0.0/0

PersistentKeepalive = 25
